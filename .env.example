# GitHub Personal Access Token
# Required for GraphQL API + higher rate limits (5000 req/hour vs 60)
# Create one at: https://github.com/settings/tokens/new
# Scopes needed: public_repo (read-only is fine for public repos)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Path to the input CSV (relative to project root)
CSV_PATH=agent-runners-census.csv

# Cache TTL in hours (default 24h — skip re-fetching)
CACHE_TTL_HOURS=24

# Port to run the server on
PORT=8000

# Admin page password — protect /admin before deploying
ADMIN_PASSWORD=change-me-before-deploying
