# GitHub Personal Access Token
# Required for GraphQL API + higher rate limits (5000 req/hour vs 60)
# Create one at: https://github.com/settings/tokens/new
# Scopes needed: public_repo (read-only for fetching) + repo (write for PR creation)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Path to the repos list file (relative to project root)
CSV_PATH=repos.txt

# Port to run the server on
PORT=8000

# Admin page password — protect /admin before deploying
ADMIN_PASSWORD=change-me-before-deploying

# Git sync — identity used when committing data/ changes
GIT_USER_NAME=OWASP Surveyor Bot
GIT_USER_EMAIL=surveyor@owasp.org

# Git sync — GitHub repo slug (owner/repo) for PR creation
GITHUB_REPO=your-org/your-repo
